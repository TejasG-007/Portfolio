ootstrap';\r\nimport Slide from 'react-reveal/Slide';\r\n\r\n\r\n\r\n\r\nconst Home = () => {\r\n    const [knowme, setknowme] = useState(false);\r\n    return (\r\n        <>\r\n           <Jumbotron className=\"bg-white\" fluid>\r\n                {/* <img src={handclose}></img> */}\r\n            <Container fluid style={{marginTop:'10%'}}>\r\n                <Row className=\"md-2 p-2 mt-5 text-center\">\r\n                    <Col sm className=\" d-none d-sm-block\">\r\n                        <Slide left>\r\n                            <Image className=\"  p-1 shadow-lg bg-dark rounded\" src={Best2} style={{ width: '100%', height: '50%', marginTop: '50px', padding: '0px' }} />\r\n\r\n                        </Slide>\r\n\r\n                    </Col>\r\n\r\n                    <Col sm  className=\"d-none d-sm-block\">\r\n                        <Slide left>\r\n                            <Image className=\" p-1 shadow-lg bg-dark rounded\" src={handclose} style={{ width: '100%', height: '50%', marginTop: '10px', }} />\r\n\r\n                        </Slide>\r\n\r\n                    </Col>\r\n                    <Col sm >\r\n                        <Slide top>\r\n                            <Image className=\" p-1 shadow-lg bg-dark rounded\" src={Best} style={{ width: '100%', height: '50%', marginTop: '80px' }} />\r\n\r\n                        </Slide>\r\n\r\n                    </Col>\r\n                    <Col sm={6} style={{ alignSelf: 'center', fontWeight: 'bold' }}>\r\n\r\n                        <Slide right> <h1 style={{ fontSize: '50px', fontWeight: 'bold', marginRight: '10px'}}>Hi,I'm Tejas Gathekar</h1><Button onClick={() => setknowme(!knowme)}\r\n                            aria-controls={knowme}\r\n                            aria-expanded=\"clicked\"\r\n                            variant=\"outline-success\">Know About me</Button>\r\n                            <Collapse in={knowme}>\r\n                                <div id=\"clicked\">\r\n                                    <br/>\r\n                                    Strong in design and integration with intuitive problem-solving skills.\r\n                                    Passionate about implementing and launching new projects. Ability to translate\r\n                                    business requirements into technical solutions. Looking to start the career as an entry-level software engineer with a reputed firm driven by technology.\r\n                        </div>\r\n                            </Collapse>\r\n                        </Slide>\r\n                    </Col>\r\n\r\n\r\n\r\n                </Row>\r\n            </Container>\r\n           </Jumbotron>\r\n        </>\r\n\r\n    );\r\n}\r\nexport default Home;","C:\\Users\\TejasG\\Desktop\\React Project Learning\\Portfolio\\src\\components\\Project\\Project.js",[],"C:\\Users\\TejasG\\Desktop\\React Project Learning\\Portfolio\\src\\components\\About\\About.js",[],"C:\\Users\\TejasG\\Desktop\\React Project Learning\\Portfolio\\src\\components\\Contact\\Contact.js",["51","52"],"C:\\Users\\TejasG\\Desktop\\React Project Learning\\Portfolio\\src\\components\\ScrollToTop.js",[],"C:\\Users\\TejasG\\Desktop\\React Project Learning\\Portfolio\\src\\components\\Project\\PData.js",[],"C:\\Users\\TejasG\\Desktop\\React Project Learning\\Portfolio\\src\\components\\Footer\\Footer.js",[],{"ruleId":"53","replacedBy":"54"},{"ruleId":"55","replacedBy":"56"},{"ruleId":"57","severity":1,"message":"58","line":45,"column":29,"nodeType":"59","endLine":45,"endColumn":52},{"ruleId":"60","severity":1,"message":"61","line":3,"column":18,"nodeType":"62","messageId":"63","endLine":3,"endColumn":21},{"ruleId":"64","severity":1,"message":"65","line":63,"column":166,"nodeType":"59","endLine":63,"endColumn":179},"no-native-reassign",["66"],"no-negated-in-lhs",["67"],"jsx-a11y/aria-proptypes","The value for aria-expanded must be a boolean.","JSXAttribute","no-unused-vars","'Row' is defined but never used.","Identifi